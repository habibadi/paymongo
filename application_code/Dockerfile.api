# Build stage
FROM golang:1.21-alpine AS builder

WORKDIR /app

# Copy go.mod and main.go
COPY go.mod ./
COPY main.go ./
COPY docs/ ./docs/

# Build the application
RUN go build -o main .

# Run stage
FROM alpine:latest

# Install curl for healthcheck
RUN apk add --no-cache curl

WORKDIR /app

COPY --from=builder /app/main .
COPY --from=builder /app/docs ./docs

# API port
EXPOSE 8080

CMD ["./main"]
